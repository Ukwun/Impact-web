# Database
DATABASE_URL=postgresql://user:password@localhost:5432/impactapp

# Next.js Public API URL
# For production (Netlify): Use Render backend
NEXT_PUBLIC_API_URL=https://impactapp-backend.onrender.com
# For development: Use local backend
# NEXT_PUBLIC_API_URL=http://localhost:3000

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Payment Gateway - Flutterwave
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=pk_test_xxx
FLUTTERWAVE_SECRET_KEY=sk_test_xxx
FLUTTERWAVE_WEBHOOK_SECRET=whsec_test_xxx

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# AWS S3 Configuration (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=impactedu-uploads

# WebSocket Configuration (Socket.IO)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Redis Configuration (For persistent rate limiting & caching)
REDIS_URL=redis://localhost:6379
# For production: REDIS_URL=redis://<username>:<password>@<host>:<port>

# Node Environment
NODE_ENV=development

# Sentry DSN for error monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Messaging queue worker auth
MESSAGING_WORKER_SECRET=change_this_worker_secret

# Delivery mode: "live" uses providers, "mock" simulates successful dispatch
MESSAGE_DELIVERY_MODE=mock

# Provider selection
SMS_PROVIDER=TERMII
WHATSAPP_PROVIDER=META

# Twilio configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Termii configuration
TERMII_API_KEY=
TERMII_SENDER_ID=ImpactEdu

# Meta WhatsApp Cloud API configuration
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=


{
  "name": "impactapp-web",
  "version": "1.0.0",
  "description": "ImpactApp - NCDF Impact Club Digital Platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:socket": "node server.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "load-test": "npx k6 run load-test.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@hookform/resolvers": "^3.3.0",
    "@prisma/client": "^5.20.0",
    "@sentry/nextjs": "^7.15.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "critters": "^0.0.23",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.0",
    "file-type": "^21.3.0",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^0.293.0",
    "next": "^14.0.0",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "recharts": "^2.10.0",
    "redis": "^5.11.0",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "k6": "^0.0.0",
    "prettier": "^3.1.0",
    "prisma": "^5.20.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  }
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id                    String      @id @default(cuid())
  email                 String      @unique
  firstName             String
  lastName              String
  phone                 String?
  avatar                String?
  passwordHash          String
  role                  UserRole
  state                 String
  location              String?
  institution           String?
  verified              Boolean     @default(false)
  
  // NCDF Programme Assignment
  programme             Programme?  @default(IMPACT_SCHOOL)
  
  // Membership Tier (LEGACY - kept for backwards compatibility)
  membershipTierId      String?
  membershipTier        MembershipTier? @relation(fields: [membershipTierId], references: [id], onDelete: SetNull)
  membershipStatus      MembershipStatus @default(ACTIVE)
  membershipJoinedAt    DateTime?
  
  // Account status
  emailVerified         Boolean     @default(false)
  emailVerifiedAt       DateTime?
  emailVerificationToken String?
  isActive              Boolean     @default(true)
  lastLoginAt           DateTime?
  
  // Password reset
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  
  // Onboarding
  onboardingResponse    OnboardingResponse?
  
  // Parent-Child Relationships
  children              ParentChild[] @relation("Parent")
  parents               ParentChild[] @relation("Child")
  
  // Relations
  enrollments           Enrollment[]
  quizAttempts          QuizAttempt[]
  assignments           AssignmentSubmission[]
  activitySubmissions   ActivitySubmission[] @relation("ActivitySubmissionsCreated")
  eventRegistrations    EventRegistration[]
  grades                Grade[]
  certificates          Certificate[]
  notifications         Notification[]
  achievements          UserAchievement[]
  mentorSessions        MentorSession[] @relation("Mentor")
  menteeOf              MentorSession[] @relation("Mentee")
  createdCourses        Course[] @relation("CreatedBy")
  createdEvents         Event[] @relation("CreatedBy")
  liveSessions          LiveSession[] @relation("LiveSessionsFacilitator")
  liveSessionAttendance LiveSessionAttendance[] @relation("LiveSessionAttendance")
  payments              Payment[]
  leaderboard           LeaderboardEntry?
  messagesSent          Message[] @relation("MessagesSent")
  messagesReceived      Message[] @relation("MessagesReceived")
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([email])
  @@index([role])
  @@index([state])
  @@index([programme])
  @@index([membershipTierId])
  @@index([membershipStatus])
}

enum UserRole {
  STUDENT
  PARENT
  FACILITATOR
  SCHOOL_ADMIN
  UNI_MEMBER
  CIRCLE_MEMBER
  MENTOR
  ADMIN
}

enum Programme {
  IMPACT_SCHOOL
  IMPACT_UNI
  IMPACT_CIRCLE
}

// ============================================================================
// MEMBERSHIP TIER SYSTEM (NEW)
// ============================================================================

enum MembershipTierType {
  STUDENT_MEMBER
  CAMPUS_MEMBER
  YOUNG_PROFESSIONAL_MEMBER
  MENTOR_FACULTY_MEMBER
  CHAPTER_LEAD_AMBASSADOR
  INSTITUTIONAL_PARTNER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  EXPIRED
}

model MembershipTier {
  id                    String              @id @default(cuid())
  tierType              MembershipTierType  @unique
  name                  String              // Human-readable name
  description           String?
  
  // Benefits/Features
  canAccessLearning     Boolean             @default(true)
  canParticipateEvents  Boolean             @default(true)
  canAccessCommunity    Boolean             @default(true)
  canAccessMentorship   Boolean             @default(false)
  canCreateContent      Boolean             @default(false)
  canManageChapter      Boolean             @default(false)
  
  // Learning Pathways (linked to this tier)
  maxCoursesAccess      Int?                // null = unlimited
  maxEventsAccess       Int?                // null = unlimited
  
  // Member relations
  users                 User[]
  
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([tierType])
}

// ============================================================================
// ONBOARDING
// ============================================================================

model OnboardingResponse {
  id                    String      @id @default(cuid())
  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                  UserRole
  preferences           Json        // Stores role-specific preferences as JSON
  completedAt           DateTime    @default(now())
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([userId])
  @@index([role])
}

// ============================================================================
// PARENT-CHILD RELATIONSHIPS
// ============================================================================

model ParentChild {
  id                    String      @id @default(cuid())
  parentId              String
  parent                User        @relation("Parent", fields: [parentId], references: [id], onDelete: Cascade)
  
  childId               String
  child                 User        @relation("Child", fields: [childId], references: [id], onDelete: Cascade)
  
  relationship          ParentalRelationship @default(PARENT)
  isActive              Boolean     @default(true)
  
  // Permissions granted to parent
  canViewProgress       Boolean     @default(true)
  canViewAttendance     Boolean     @default(true)
  canViewGrades         Boolean     @default(true)
  canViewCertificates   Boolean     @default(true)
  canReceiveAlerts      Boolean     @default(true)
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@index([isActive])
}

enum ParentalRelationship {
  PARENT
  GUARDIAN
  LEGAL_GUARDIAN
}

model Course {
  id                    String      @id @default(cuid())
  title                 String
  description           String
  thumbnail            String?
  difficulty            Difficulty  @default(BEGINNER)
  duration              Int         // in minutes
  language              String      @default("English")
  
  // Course metadata
  instructor            String
  createdById           String
  createdBy             User        @relation("CreatedBy", fields: [createdById], references: [id])
  
  // Content structure
  modules               Module[]
  lessons               Lesson[]
  quizzes               Quiz[]
  assignments           Assignment[]
  activities            Activity[]
  liveSessions          LiveSession[]
  
  // Enrollment tracking
  enrollments           Enrollment[]
  
  // Grades tracking
  grades                Grade[]
  
  // Course settings
  isPublished           Boolean     @default(false)
  isArchived            Boolean     @default(false)
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([createdById])
  @@index([isPublished])
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Module {
  id                    String      @id @default(cuid())
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  title                 String
  description           String?
  order                 Int
  
  // Learning layer configuration
  learningLayers        String[]    @default(["LEARN", "APPLY", "ENGAGE_LIVE", "SHOW_PROGRESS"])
  ageGroup              String?     // e.g., "7-11", "12-14", "15-18", "18+"
  subjectStrand         String?     // e.g., "Financial Literacy", "Entrepreneurship"
  competencies          String[]    @default([])  // Learning competencies
  estimatedWeeks        Int         @default(1)
  
  // Relations
  lessons               Lesson[]
  quizzes               Quiz[]
  activities            Activity[]
  liveSessions          LiveSession[]
  moduleProgress        ModuleProgress[]
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([courseId, order])
  @@index([courseId])
}

model Lesson {
  id                    String      @id @default(cuid())
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  moduleId              String?
  module                Module?     @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  
  title                 String
  description           String?
  content               String?     // Rich text content
  videoUrl              String?
  videoThumbnail        String?
  duration              Int         // in minutes
  order                 Int
  
  // Learning layer & pedagogy
  learningLayer         String      @default("LEARN") // LEARN, APPLY, ENGAGE_LIVE, SHOW_PROGRESS
  instructions          String?
  learningObjectives    String[]    @default([])
  facilitatorNotes      String?
  prerequisites         String[]    @default([])
  
  materials             LessonMaterial[]
  notes                 LessonNote[]
  progress              LessonProgress[]
  activities            Activity[]
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([courseId])
  @@index([moduleId])
}

model LessonMaterial {
  id                    String      @id @default(cuid())
  lessonId              String
  lesson                Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  title                 String
  type                  String      // pdf, document, video, etc.
  url                   String
  fileSize              Int?
  
  createdAt             DateTime    @default(now())

  @@index([lessonId])
}

model LessonProgress {
  id                    String      @id @default(cuid())
  lessonId              String
  lesson                Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  enrollmentId          String
  enrollment            Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  
  secondsWatched        Int         @default(0)
  isCompleted           Boolean     @default(false)
  completedAt           DateTime?
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([lessonId, enrollmentId])
  @@index([lessonId])
  @@index([enrollmentId])
}

model LessonNote {
  id                    String      @id @default(cuid())
  lessonId              String
  lesson                Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  enrollmentId          String
  enrollment            Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  
  content               String
  timestamp             Int?        // Timestamp in lesson where note was taken
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([lessonId])
  @@index([enrollmentId])
}

// ============================================================================
// CLASSROOM LEARNING - ACTIVITY LAYER (APPLY)
// ============================================================================

model Activity {
  id                    String      @id @default(cuid())
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  moduleId              String?
  module                Module?     @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  
  lessonId              String?
  lesson                Lesson?     @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  
  title                 String
  description           String?
  instructions          String?     // Rich text
  activityType          String      @default("WORKSHEET") // WORKSHEET, TASK, REFLECTION, MINI_CHALLENGE, JOURNAL
  dueDate               DateTime?
  maxPoints             Int         @default(100)
  rubric                String?     // JSON rubric criteria
  attachments           String[]    @default([])
  order                 Int         @default(0)
  isPublished           Boolean     @default(true)
  
  submissions           ActivitySubmission[]
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([courseId])
  @@index([moduleId])
  @@index([lessonId])
}

model ActivitySubmission {
  id                    String      @id @default(cuid())
  activityId            String
  activity              Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade, name: "ActivitySubmissionsCreated")
  
  enrollmentId          String?
  enrollment            Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull, name: "ActivitySubmissions")
  
  content               String?     // Text response or notes
  attachments           String[]    @default([])
  
  isSubmitted           Boolean     @default(false)
  submittedAt           DateTime?
  
  score                 Int?
  feedback              String?
  gradedBy              String?
  gradedAt              DateTime?
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([activityId, userId])
  @@index([activityId])
  @@index([userId])
  @@index([enrollmentId])
}

// ============================================================================
// CLASSROOM LEARNING - LIVE SESSION LAYER (ENGAGE_LIVE)
// ============================================================================

model LiveSession {
  id                    String      @id @default(cuid())
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  moduleId              String?
  module                Module?     @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  
  title                 String
  description           String?
  facilitatorId         String
  facilitator           User        @relation(fields: [facilitatorId], references: [id], onDelete: Restrict, name: "LiveSessionsFacilitator")
  
  startTime             DateTime
  endTime               DateTime
  maxParticipants       Int?
  
  // Session metadata
  meetingUrl            String?
  recordingUrl          String?
  status                String      @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED, CANCELLED
  sessionType           String      @default("CLASSROOM") // CLASSROOM, BREAKOUT, Q_AND_A, SIMULATION, CLINIC
  
  // Interactive features
  breakoutGroups        Int         @default(0)
  hasPolls              Boolean     @default(false)
  hasQandA              Boolean     @default(false)
  hasScreenShare        Boolean     @default(true)
  
  // Attendance tracking
  attendance            LiveSessionAttendance[]
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([courseId])
  @@index([facilitatorId])
}

model LiveSessionAttendance {
  id                    String      @id @default(cuid())
  sessionId             String
  session               LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade, name: "LiveSessionAttendance")
  
  joinedAt              DateTime?
  leftAt                DateTime?
  attendanceMinutes     Int         @default(0)
  attended              Boolean     @default(false)
  
  createdAt             DateTime    @default(now())

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

// ============================================================================
// MODULE & LEARNING PROGRESS TRACKING (SHOW_PROGRESS)
// ============================================================================

model ModuleProgress {
  id                    String      @id @default(cuid())
  moduleId              String
  module                Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  
  enrollmentId          String
  enrollment            Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade, name: "ModuleProgress")
  
  // Layer completion tracking
  learnLayerCompleted   Boolean     @default(false)
  applyLayerCompleted   Boolean     @default(false)
  engageLiveLayerCompleted Boolean  @default(false)
  showProgressCompleted Boolean     @default(false)
  
  // Overall progress
  progressPercentage    Float       @default(0)
  completedAt           DateTime?
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([moduleId, enrollmentId])
  @@index([moduleId])
  @@index([enrollmentId])
}

// ============================================================================
// QUIZZES & ASSESSMENTS
// ============================================================================

model Quiz {
  id                    String      @id @default(cuid())
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  moduleId              String?
  module                Module?     @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  
  title                 String
  description           String?
  duration              Int         // in minutes
  passingScore          Int         @default(70) // percentage
  totalPoints           Int         @default(100)
  allowRetake           Boolean     @default(true)
  showResults           Boolean     @default(true)
  
  questions             QuizQuestion[]
  attempts              QuizAttempt[]
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([courseId])
}

model QuizQuestion {
  id                    String      @id @default(cuid())
  quizId                String
  quiz                  Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  order                 Int
  type                  QuestionType
  questionText          String
  explanation           String?
  points                Int         @default(1)
  
  // MCQ/True-False options
  options               String[]    // JSON array of options
  correctAnswer         String      // Could be index for MCQ or "true"/"false"
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([quizId, order])
  @@index([quizId])
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

model QuizAttempt {
  id                    String      @id @default(cuid())
  quizId                String
  quiz                  Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  enrollmentId          String?
  enrollment            Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  
  answers               QuizAnswer[]
  score                 Int?
  scoredOutOf           Int
  percentageScore       Int?
  isPassed              Boolean?
  
  startedAt             DateTime    @default(now())
  submittedAt           DateTime?
  completedAt           DateTime?

  @@index([quizId])
  @@index([userId])
  @@index([enrollmentId])
}

model QuizAnswer {
  id                    String      @id @default(cuid())
  quizAttemptId         String
  quizAttempt           QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  
  questionId            String
  answer                String      // User's answer
  isCorrect             Boolean?
  pointsEarned          Int?
  
  createdAt             DateTime    @default(now())

  @@index([quizAttemptId])
}

// ============================================================================
// ASSIGNMENTS
// ============================================================================

model Assignment {
  id                    String      @id @default(cuid())
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  title                 String
  description           String
  instructions          String      // Rich text
  rubric                RubricItem[]
  
  dueDate               DateTime
  maxPoints             Int         @default(100)
  allowLateSubmission   Boolean     @default(false)
  
  submissions           AssignmentSubmission[]
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([courseId])
}

model RubricItem {
  id                    String      @id @default(cuid())
  assignmentId          String
  assignment            Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  criterion             String
  points                Int
  description           String?
  
  @@index([assignmentId])
}

model AssignmentSubmission {
  id                    String      @id @default(cuid())
  assignmentId          String
  assignment            Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  enrollmentId          String?
  enrollment            Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  
  files                 SubmissionFile[]
  comments              String?
  
  isSubmitted           Boolean     @default(false)
  submittedAt           DateTime?
  isLate                Boolean     @default(false)
  
  isGraded              Boolean     @default(false)
  score                 Int?
  feedback              String?
  gradedAt              DateTime?
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
  @@index([enrollmentId])
}

model SubmissionFile {
  id                    String      @id @default(cuid())
  submissionId          String
  submission            AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  fileName              String
  fileUrl               String
  fileSize              Int
  mimeType              String
  
  uploadedAt            DateTime    @default(now())

  @@index([submissionId])
}

// ============================================================================
// ENROLLMENT & PROGRESS
// ============================================================================

model Enrollment {
  id                    String      @id @default(cuid())
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  progress              Float       @default(0)  // percentage
  isCompleted           Boolean     @default(false)
  completedAt           DateTime?
  
  lessonProgress        LessonProgress[]
  lessonNotes           LessonNote[]
  quizAttempts          QuizAttempt[]
  assignmentSubmissions AssignmentSubmission[]
  activitySubmissions   ActivitySubmission[] @relation("ActivitySubmissions")
  moduleProgress        ModuleProgress[]     @relation("ModuleProgress")
  payment               Payment?
  
  enrolledAt            DateTime    @default(now())
  lastAccessedAt        DateTime    @default(now())

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model Grade {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  score                 Int
  percentage            Int
  letterGrade           String
  feedback              String?
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ============================================================================
// CERTIFICATES & ACHIEVEMENTS
// ============================================================================

model Certificate {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  courseId              String
  
  certificateNumber     String      @unique
  title                 String
  issuedDate            DateTime    @default(now())
  expiryDate            DateTime?
  
  qrCode                String?
  certificateUrl        String?
  
  createdAt             DateTime    @default(now())

  @@index([userId])
}

model UserAchievement {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  badge                 String      // Badge name/key
  title                 String
  description           String?
  icon                  String?
  
  unlockedAt            DateTime    @default(now())

  @@unique([userId, badge])
  @@index([userId])
}

// ============================================================================
// LEADERBOARD SYSTEM
// ============================================================================

model LeaderboardEntry {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Scoring system
  totalScore            Int         @default(0)  // Total points from all activities
  coursesCompleted      Int         @default(0)  // Number of courses completed
  quizzesPassed         Int         @default(0)  // Number of quizzes passed
  assignmentsSubmitted  Int         @default(0)  // Number of assignments submitted
  perfectScores         Int         @default(0)  // Number of perfect scores (100%)
  
  // Activity tracking
  streakDays            Int         @default(0)  // Current login streak
  totalLogins           Int         @default(0)  // Total login count
  studyTimeMinutes      Int         @default(0)  // Total study time in minutes
  
  // Rankings (computed fields)
  globalRank            Int?        // Global ranking position
  stateRank             Int?        // State-specific ranking
  schoolRank            Int?        // School-specific ranking
  
  // Metadata
  lastActivityAt        DateTime    @default(now())
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([userId])
  @@index([totalScore])
  @@index([globalRank])
  @@index([stateRank])
  @@index([schoolRank])
  @@index([lastActivityAt])
}

// ============================================================================
// EVENTS
// ============================================================================

model Event {
  id                    String      @id @default(cuid())
  title                 String
  description           String
  image                 String?
  
  eventDate             DateTime
  startTime             String
  endTime               String
  
  venue                 String
  location              String
  
  eventType             EventType
  
  capacity              Int
  registrations         EventRegistration[]
  
  createdById           String
  createdBy             User        @relation("CreatedBy", fields: [createdById], references: [id])
  
  isPublished           Boolean     @default(true)
  isCancelled           Boolean     @default(false)
  cancelledReason       String?
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([createdById])
  @@index([eventDate])
  @@index([eventType])
}

enum EventType {
  NATIONAL
  STATE
  SCHOOL
  CIRCLE
  WEBINAR
  WORKSHOP
}

model EventRegistration {
  id                    String      @id @default(cuid())
  eventId               String
  event                 Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status                RegistrationStatus @default(REGISTERED)
  attendedAt            DateTime?
  
  registeredAt          DateTime    @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

enum RegistrationStatus {
  REGISTERED
  ATTENDED
  CANCELLED
  NO_SHOW
}

// ============================================================================
// TESTIMONIALS
// ============================================================================

model Testimonial {
  id                    String      @id @default(cuid())
  
  authorName            String
  authorRole            String      // "Student Success", "Mentor Impact", "Partner Story"
  authorAvatar          String?
  
  quote                 String
  rating                Int         @default(5)
  
  category              String      // "student", "mentor", "partner"
  
  isPublished           Boolean     @default(true)
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([category])
  @@index([isPublished])
}

// ============================================================================
// MENTORING
// ============================================================================

model MentorSession {
  id                    String      @id @default(cuid())
  mentorId              String
  mentor                User        @relation("Mentor", fields: [mentorId], references: [id], onDelete: Cascade)
  
  menteeId              String
  mentee                User        @relation("Mentee", fields: [menteeId], references: [id], onDelete: Cascade)
  
  title                 String
  description           String?
  duration              Int         // in minutes
  
  scheduledAt           DateTime
  startedAt             DateTime?
  endedAt               DateTime?
  
  notes                 String?
  feedback              String?
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([mentorId])
  @@index([menteeId])
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title                 String
  message               String
  type                  NotificationType
  link                  String?
  relatedId             String?     // ID of related resource (submission, message, etc.)
  
  isRead                Boolean     @default(false)
  readAt                DateTime?
  
  createdAt             DateTime    @default(now())

  @@index([userId])
  @@index([isRead])
}

enum NotificationType {
  COURSE_ENROLLMENT
  QUIZ_SUBMITTED
  ASSIGNMENT_GRADED
  GRADE_RECEIVED
  NEW_MESSAGE
  MESSAGE_RECEIVED
  EVENT_REMINDER
  CERTIFICATE_EARNED
  MENTION
  SYSTEM
}

// ============================================================================
// PAYMENTS
// ============================================================================

model Payment {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  enrollmentId          String?     @unique
  enrollment            Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  
  amount                Decimal     @db.Decimal(10, 2)
  currency              String      @default("NGN")
  purpose               String      // "course_enrollment", "subscription", "workshop"
  description           String?
  
  // Payment method
  paymentMethod         PaymentMethod
  
  // Flutterwave integration
  flutterWaveRef        String?     @unique
  transactionId         String?     @unique
  authorizationUrl      String?
  
  // Bank transfer details
  bankName              String?
  accountNumber         String?
  accountName           String?
  
  // Payment status
  status                PaymentStatus @default(PENDING)
  
  // Metadata
  metadata              Json?
  
  // Timestamps
  initiatedAt           DateTime    @default(now())
  completedAt           DateTime?
  paidAt                DateTime?
  failedAt              DateTime?
  failureReason         String?
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentMethod])
  @@index([flutterWaveRef])
}

enum PaymentMethod {
  FLUTTERWAVE
  BANK_TRANSFER
  CARD
}

enum PaymentStatus {
  PENDING
  INITIATED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

// ============================================================================
// SYSTEM ALERTS (Real-time Monitoring & Admin Dashboard)
// ============================================================================

enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
}

model SystemAlert {
  id                    String      @id @default(cuid())
  title                 String
  message               String
  severity              AlertSeverity
  category              String      // "System", "Performance", "Security", "Features", etc.
  
  // Alert status
  resolved              Boolean     @default(false)
  resolvedAt            DateTime?
  
  // Metadata for tracking
  source                String?     // Where the alert came from (e.g., "monitoring", "manual")
  metadata              Json?       // Additional data
  
  // Timestamps
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([severity])
  @@index([resolved])
  @@index([category])
  @@index([createdAt])
}

// ============================================================================
// MESSAGING SYSTEM
// ============================================================================

model Message {
  id                    String      @id @default(cuid())
  
  senderId              String
  sender                User        @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  
  recipientId           String
  recipient             User        @relation("MessagesReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  
  subject               String
  content               String      @db.Text
  messageType           String      @default("GENERAL") // GENERAL, FACILITATOR_TO_STUDENT, PARENT_TO_FACILITATOR, etc.
  
  // Read status
  isRead                Boolean     @default(false)
  readAt                DateTime?
  
  // Timestamps
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([senderId])
  @@index([recipientId])
  @@index([isRead])
  @@index([createdAt])
}
